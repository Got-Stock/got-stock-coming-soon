{
  "buildCommand": "",
  "outputDirectory": ".",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": [
    {
      "source": "/:path((?!/index\.html$).*)",
      "destination": "/index.html"
    }
  ]
}
